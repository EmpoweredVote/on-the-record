# Base URL of the ev-accounts API (no trailing slash).
# Build-time only — not exposed to the browser.
EV_ACCOUNTS_URL=https://ev-accounts.onrender.com

# Same URL, baked into the client bundle for the /search page's
# runtime requests. The SITE origin must also be in ev-accounts'
# CORS_ORIGIN allowlist for production.
NEXT_PUBLIC_EV_ACCOUNTS_URL=https://ev-accounts.onrender.com

# Canonical origin of the static site (no trailing slash).
# Build-time only — used for sitemap.xml entries and OpenGraph canonical URLs.
# Set this in the Render static site's environment variables.
SITE_URL=https://on-the-record.onrender.com
