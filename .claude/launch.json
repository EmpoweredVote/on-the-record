{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web",
      "port": 3000
    },
    {
      "name": "static-export",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "web/out", "-l", "4173"],
      "port": 4173
    },
    {
      "name": "gui",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "gui"],
      "port": 8000
    }
  ]
}
